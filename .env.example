# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=agentswarm

# Hermes LLM API
HERMES_API_BASE=https://hermes.example.com/v1
HERMES_API_KEY=sk-xxxxx
HERMES_MODEL=hunyuan-2.0-instruct-20251111

# Docker Swarm
SWARM_NETWORK_NAME=agentswarm-net

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
LOG_LEVEL=info

# Worker (由 SwarmManager 注入，无需手动配置)
# GATEWAY_URL=http://gateway:8000
# AGENT_NODE_ID=<uuid>
